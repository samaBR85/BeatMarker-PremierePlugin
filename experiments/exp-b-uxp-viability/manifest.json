{
  "manifestVersion": 5,
  "id": "com.beatmarker.exp-b",
  "name": "BeatMarker — Exp B: UXP Viability",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.0.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "exp-b-panel",
      "label": "BeatMarker Exp-B",
      "minimumSize": { "width": 300, "height": 500 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 340, "height": 600 },
      "preferredFloatingSize": { "width": 340, "height": 600 }
    }
  ]
}
